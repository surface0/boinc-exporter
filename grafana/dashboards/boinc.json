{
  "title": "BOINC Metrics",
  "uid": "boinc-metrics-v1",
  "schemaVersion": 38,
  "version": 13,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "timezone": "browser",
  "tags": ["boinc"],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "pluginId": "prometheus",
        "label": "Datasource",
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "BOINC Status",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "boinc_up", "legendFormat": "{{instance}}", "refId": "A" }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN", "color": "red" },
                "1": { "text": "UP",   "color": "green" }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",   "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Total Credits (All Projects)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum(max by (project) (boinc_project_total_credit))", "legendFormat": "Total", "refId": "A" }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "decimals": 2,
          "unit": "none",
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Avg Daily Credits (All Projects)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum(max by (project) (boinc_project_avg_credit))", "legendFormat": "Daily Avg", "refId": "A" }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "decimals": 2,
          "unit": "none",
          "color": { "mode": "fixed", "fixedColor": "purple" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "purple", "value": null }]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Executing Tasks",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 4, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "boinc_tasks_total{state=\"executing\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "unit": "none",
          "color": { "mode": "fixed", "fixedColor": "green" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Tasks by State (All Hosts)",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 4, "x": 10, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (state) (boinc_tasks_total)",
          "legendFormat": "{{state}}",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "valueMode": "color"
      },
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "unit": "none",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Active Task Progress (All Hosts / All Tasks)",
      "type": "table",
      "gridPos": { "h": 16, "w": 10, "x": 14, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "boinc_task_fraction_done",
          "refId": "A",
          "instant": true,
          "format": "table"
        }
      ],
      "options": {
        "sortBy": [{ "displayName": "Progress", "desc": true }]
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "instance": "Host",
              "name": "Task",
              "project_url": "Project",
              "Value": "Progress"
            },
            "excludeByName": {
              "Time": true,
              "job": true,
              "__name__": true
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "decimals": 1 },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Progress" },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": { "type": "gauge", "mode": "lcd", "valueDisplayMode": "text" }
              },
              { "id": "color", "value": { "mode": "continuous-YlRd" } },
              { "id": "min", "value": 0 },
              { "id": "max", "value": 1 }
            ]
          }
        ]
      }
    },
    {
      "id": 7,
      "title": "Total Credits by Project (All Hosts)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 14, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "max by (project) (boinc_project_total_credit)",
          "legendFormat": "{{project}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 2,
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 8,
      "title": "Avg Daily Credits by Project (All Hosts)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 14, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "max by (project) (boinc_project_avg_credit)",
          "legendFormat": "{{project}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 2,
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 9,
      "title": "Jobs Success by Host (stacked by Project)",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 7, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (instance, project) (boinc_project_jobs_success_total)",
          "refId": "A",
          "instant": true,
          "format": "table"
        }
      ],
      "options": {
        "xTickLabelRotation": 0,
        "groupWidth": 0.7,
        "barWidth": 0.9,
        "stacking": "normal",
        "orientation": "horizontal",
        "showValue": "never",
        "legend": { "displayMode": "list", "placement": "right" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0,
          "color": { "mode": "palette-classic" }
        }
      },
      "transformations": [
        {
          "id": "organize",
          "options": { "excludeByName": { "Time": true } }
        },
        {
          "id": "partitionByValues",
          "options": { "fields": ["project"], "keepFields": false, "naming": { "asLabels": true } }
        },
        {
          "id": "joinByField",
          "options": { "byField": "instance", "mode": "outer" }
        }
      ]
    },
    {
      "id": 10,
      "title": "Jobs Error by Host (stacked by Project)",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 7, "x": 7, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (instance, project) (boinc_project_jobs_error_total)",
          "refId": "A",
          "instant": true,
          "format": "table"
        }
      ],
      "options": {
        "xTickLabelRotation": 0,
        "groupWidth": 0.7,
        "barWidth": 0.9,
        "stacking": "normal",
        "orientation": "horizontal",
        "showValue": "never",
        "legend": { "displayMode": "list", "placement": "right" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0,
          "color": { "mode": "palette-classic" }
        }
      },
      "transformations": [
        {
          "id": "organize",
          "options": { "excludeByName": { "Time": true } }
        },
        {
          "id": "partitionByValues",
          "options": { "fields": ["project"], "keepFields": false, "naming": { "asLabels": true } }
        },
        {
          "id": "joinByField",
          "options": { "byField": "instance", "mode": "outer" }
        }
      ]
    },
    {
      "id": 11,
      "title": "Host Total Credit (by Host)",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 5, "x": 14, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (instance) (boinc_host_total_credit)",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "valueMode": "text"
      },
      "fieldConfig": {
        "defaults": {
          "decimals": 2,
          "unit": "none",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10000 },
              { "color": "orange", "value": 20000 },
              { "color": "red", "value": 30000 }
            ]
          }
        }
      }
    },
    {
      "id": 12,
      "title": "Host Avg Daily Credit (by Host)",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 5, "x": 19, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (instance) (boinc_host_avg_credit)",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "valueMode": "text"
      },
      "fieldConfig": {
        "defaults": {
          "decimals": 2,
          "unit": "none",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "yellow", "value": 250 }
            ]
          }
        }
      }
    },
    {
      "id": 13,
      "title": "Executing Tasks Timeline (by Host)",
      "type": "state-timeline",
      "gridPos": { "h": 8, "w": 10, "x": 14, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (instance) (boinc_tasks_total{state=\"executing\"})",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "options": {
        "mergeValues": true,
        "showValue": "auto",
        "alignValue": "center",
        "rowHeight": 0.9,
        "legend": { "showLegend": false, "displayMode": "hidden", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "min": 1,
          "max": 10,
          "custom": { "fillOpacity": 75, "lineWidth": 0 },
          "color": { "mode": "continuous-GrYlRd" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        }
      }
    }
  ]
}
